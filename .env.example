# PostgreSQL
POSTGRES_DB=yandexbug
POSTGRES_USER=yandexbug
POSTGRES_PASSWORD=yandexbug_secret

# DATABASE_URL — внутри docker сети используется имя сервиса 'postgres'
DATABASE_URL=postgres://yandexbug:yandexbug_secret@postgres:5432/yandexbug?sslmode=disable

# Redis — внутри docker сети
REDIS_URL=redis://redis:6379/0

# Telegram bot
# Получите токен у @BotFather. Если не нужен бот — оставьте пустым или фейковое значение,
# в этом случае telegram-bot будет логировать ошибку, но остальные сервисы продолжат работать.
TELEGRAM_BOT_TOKEN=put_your_token_here

# Порты
BACKEND_PORT=8080
FRONTEND_PORT=3000
